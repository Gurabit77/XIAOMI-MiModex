{
  "$schema": "https://raw.githubusercontent.com/nicklasxyz/tauri-v2-schema/refs/heads/main/src/schema.json",
  "productName": "MiModex",
  "version": "1.0.0",
  "identifier": "com.mimodex.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "MiModex",
        "width": 1500,
        "height": 1000,
        "minWidth": 1180,
        "minHeight": 760,
        "center": true,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; media-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": [
      "bin/mimo-code-engine"
    ],
    "resources": {
      "resources/mimo-code": "mimo-code"
    },
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "files": {},
      "hardenedRuntime": false,
      "entitlements": null,
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "infoPlist": "Info.plist"
    }
  }
}
